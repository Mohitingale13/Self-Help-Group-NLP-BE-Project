# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000

# ─── Database ────────────────────────────────────────────────────────────────
# Without DATABASE_URL the app runs with in-memory storage (data resets on restart).
# Set this to use a persistent Supabase (or any PostgreSQL) database.

# Supabase – use the "Transaction" pooler URI from:
#   Supabase Dashboard → Project → Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Local PostgreSQL example:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/shgrecords
